{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@/*": ["./src/*"],
      "@chg-ds/unified-design-system": ["./src/index.ts"],
      "@chg-ds/unified-design-system/styles.css": ["./src/styles.css"],
      "uds-tailwind-test": ["./src/index.ts"],
      "uds-tailwind-test/styles.css": ["./src/styles.css"],
      "uds-tailwind-test/tokens.css": ["./src/tokens.css"],
      "uds-tailwind-test/fonts.css": ["./src/fonts.css"]
    }
  },
  "include": [
    "src/index.ts",
    "src/components/**/*",
    "src/hooks/**/*",
    "src/lib/**/*",
    "src/fontsource.d.ts"
  ],
  "exclude": [
    "src/docs/**/*",
    "src/App.tsx",
    "src/main.tsx"
  ]
}
