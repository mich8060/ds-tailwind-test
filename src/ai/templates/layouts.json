{
  "contractName": "uds.ai.layout-templates",
  "schemaVersion": "1.0.0",
  "templates": [
    {
      "id": "auth-form-panel",
      "patternId": "AuthForm",
      "intent": "Authentication form with one primary action and optional secondary action.",
      "tags": [
        "form",
        "auth",
        "panel"
      ],
      "slots": {
        "title": "Sign in",
        "subtitle": "Use your work account",
        "primaryActionLabel": "Sign in",
        "secondaryActionLabel": "Forgot password?"
      },
      "tree": {
        "type": "Container",
        "props": {
          "appearance": "transparent",
          "padding": "large",
          "gap": "--uds-spacing-24"
        },
        "children": [
          {
            "type": "Container",
            "props": {
              "appearance": "default",
              "padding": "large",
              "gap": "--uds-spacing-16"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "variant": "heading-24",
                  "text": "{{title}}"
                }
              },
              {
                "type": "Text",
                "props": {
                  "variant": "body-16",
                  "text": "{{subtitle}}"
                }
              },
              {
                "type": "Field",
                "children": [
                  {
                    "type": "TextInput",
                    "props": {
                      "type": "email"
                    }
                  }
                ]
              },
              {
                "type": "Field",
                "children": [
                  {
                    "type": "TextInput",
                    "props": {
                      "type": "password"
                    }
                  }
                ]
              },
              {
                "type": "Layout",
                "props": {
                  "direction": "column",
                  "gap": "--uds-spacing-12"
                },
                "children": [
                  {
                    "type": "Button",
                    "props": {
                      "appearance": "primary",
                      "label": "{{primaryActionLabel}}"
                    }
                  },
                  {
                    "type": "Button",
                    "props": {
                      "appearance": "text",
                      "label": "{{secondaryActionLabel}}"
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "constraints": [
        "Keep max one primary Button in the section.",
        "Wrap all form controls with Field."
      ],
      "priority": "first-choice",
      "recommendedFor": [
        "figma-make"
      ]
    },
    {
      "id": "dashboard-table-summary",
      "patternId": "DataTablePage",
      "intent": "Summary header with data table and row actions.",
      "tags": [
        "dashboard",
        "table",
        "summary"
      ],
      "slots": {
        "heading": "Open Requests",
        "primaryActionLabel": "Create request"
      },
      "tree": {
        "type": "Container",
        "props": {
          "appearance": "transparent",
          "padding": "large",
          "gap": "--uds-spacing-24"
        },
        "children": [
          {
            "type": "Toolbar",
            "props": {
              "title": "{{heading}}"
            }
          },
          {
            "type": "Container",
            "props": {
              "appearance": "default",
              "padding": "large",
              "gap": "--uds-spacing-16"
            },
            "children": [
              {
                "type": "Layout",
                "props": {
                  "direction": "row",
                  "gap": "--uds-spacing-16"
                },
                "children": [
                  {
                    "type": "Statistics",
                    "props": {
                      "label": "Open Requests",
                      "value": "24",
                      "icon": "Briefcase",
                      "iconAccent": "blue"
                    }
                  },
                  {
                    "type": "Statistics",
                    "props": {
                      "label": "Pending Review",
                      "value": "7",
                      "icon": "WarningCircle",
                      "iconAccent": "orange"
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "Container",
            "props": {
              "appearance": "secondary",
              "padding": "large",
              "gap": "--uds-spacing-12"
            },
            "children": [
              {
                "type": "Layout",
                "props": {
                  "justifyContent": "space-between",
                  "alignItems": "center",
                  "gap": "--uds-spacing-16"
                },
                "children": [
                  {
                    "type": "Status",
                    "props": {
                      "label": "Queue status",
                      "variant": "orange"
                    }
                  },
                  {
                    "type": "Button",
                    "props": {
                      "appearance": "primary",
                      "label": "{{primaryActionLabel}}"
                    }
                  }
                ]
              },
              {
                "type": "Table",
                "children": [
                  {
                    "type": "Status",
                    "props": {
                      "label": "Ready",
                      "variant": "green"
                    }
                  },
                  {
                    "type": "Tag",
                    "props": {
                      "label": "Active",
                      "variant": "blue"
                    }
                  },
                  {
                    "type": "ActionMenu",
                    "props": {
                      "triggerLabel": "Row actions"
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "constraints": [
        "Only use allowed Table children (Tag, Status, Avatar, Button, ActionMenu, ProgressIndicator, DotStatus)."
      ],
      "priority": "first-choice",
      "recommendedFor": [
        "figma-make"
      ],
      "visualDirection": "commandCenter"
    },
    {
      "id": "settings-two-column",
      "patternId": "SettingsWorkspace",
      "intent": "Two-column settings page with form area and contextual summary card.",
      "tags": [
        "settings",
        "form",
        "two-column"
      ],
      "slots": {
        "pageTitle": "Account Settings",
        "saveLabel": "Save changes"
      },
      "tree": {
        "type": "Container",
        "props": {
          "appearance": "transparent",
          "padding": "large",
          "gap": "--uds-spacing-24"
        },
        "children": [
          {
            "type": "SectionHeader",
            "props": {
              "title": "{{pageTitle}}",
              "description": "Adjust operational preferences and review context before saving."
            }
          },
          {
            "type": "Layout",
            "props": {
              "direction": "row",
              "gap": "--uds-spacing-24"
            },
            "children": [
              {
                "type": "Container",
                "props": {
                  "appearance": "default",
                  "padding": "large",
                  "gap": "--uds-spacing-16"
                },
                "children": [
                  {
                    "type": "Field",
                    "children": [
                      {
                        "type": "TextInput",
                        "props": {
                          "type": "text"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Field",
                    "children": [
                      {
                        "type": "Dropdown"
                      }
                    ]
                  },
                  {
                    "type": "Button",
                    "props": {
                      "appearance": "primary",
                      "label": "{{saveLabel}}"
                    }
                  }
                ]
              },
              {
                "type": "Container",
                "props": {
                  "appearance": "default",
                  "padding": "large",
                  "gap": "--uds-spacing-12"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "variant": "body-16",
                      "text": "Changes apply to your profile."
                    }
                  },
                  {
                    "type": "Tag",
                    "props": {
                      "color": "neutral",
                      "label": "Profile"
                    }
                  },
                  {
                    "type": "Status",
                    "props": {
                      "label": "Last synced 2h ago",
                      "variant": "green"
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "constraints": [
        "Avoid multiple primary buttons in the same section.",
        "Use spacing tokens from the governed spacing system."
      ],
      "priority": "first-choice",
      "recommendedFor": [
        "figma-make"
      ],
      "visualDirection": "splitFocus"
    },
    {
      "id": "modal-confirmation",
      "patternId": "ModalConfirmation",
      "intent": "Confirmation flow in modal with primary and dismissive actions.",
      "tags": [
        "modal",
        "confirmation",
        "destructive"
      ],
      "slots": {
        "title": "Delete item?",
        "body": "This action cannot be undone.",
        "confirmLabel": "Delete",
        "cancelLabel": "Cancel"
      },
      "tree": {
        "type": "Modal",
        "children": [
          {
            "type": "Text",
            "props": {
              "variant": "heading-24",
              "text": "{{title}}"
            }
          },
          {
            "type": "Text",
            "props": {
              "variant": "body-16",
              "text": "{{body}}"
            }
          },
          {
            "type": "Layout",
            "props": {
              "justifyContent": "flex-end",
              "alignItems": "center",
              "gap": "--uds-spacing-12"
            },
            "children": [
              {
                "type": "Button",
                "props": {
                  "appearance": "text",
                  "label": "{{cancelLabel}}"
                }
              },
              {
                "type": "Button",
                "props": {
                  "appearance": "destructive",
                  "label": "{{confirmLabel}}"
                }
              }
            ]
          }
        ]
      },
      "constraints": [
        "Do not nest Modal inside Modal.",
        "Keep one destructive primary-like action."
      ],
      "priority": "first-choice",
      "recommendedFor": [
        "figma-make"
      ]
    },
    {
      "id": "wizard-steps-form",
      "patternId": "WizardChecklist",
      "intent": "Multi-step form shell with progress indicator and staged actions.",
      "tags": [
        "wizard",
        "steps",
        "form"
      ],
      "slots": {
        "title": "Create Job Posting",
        "nextLabel": "Next",
        "backLabel": "Back"
      },
      "tree": {
        "type": "Container",
        "props": {
          "appearance": "transparent",
          "padding": "large"
        },
        "children": [
          {
            "type": "SectionHeader",
            "props": {
              "title": "{{title}}",
              "description": "Complete each step before moving forward."
            }
          },
          {
            "type": "Layout",
            "props": {
              "direction": "row",
              "gap": "--uds-spacing-24"
            },
            "children": [
              {
                "type": "Checklist"
              },
              {
                "type": "Container",
                "props": {
                  "appearance": "default",
                  "padding": "large",
                  "gap": "--uds-spacing-16"
                },
                "children": [
                  {
                    "type": "Status",
                    "props": {
                      "label": "Step 2 of 5",
                      "variant": "blue"
                    }
                  },
                  {
                    "type": "Field",
                    "children": [
                      {
                        "type": "TextInput",
                        "props": {
                          "type": "text"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Field",
                    "children": [
                      {
                        "type": "Textarea"
                      }
                    ]
                  },
                  {
                    "type": "Layout",
                    "props": {
                      "justifyContent": "space-between",
                      "alignItems": "center",
                      "gap": "--uds-spacing-12"
                    },
                    "children": [
                      {
                        "type": "Button",
                        "props": {
                          "appearance": "text",
                          "label": "{{backLabel}}"
                        }
                      },
                      {
                        "type": "Button",
                        "props": {
                          "appearance": "primary",
                          "label": "{{nextLabel}}"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      "constraints": [
        "Fields must contain form controls.",
        "Keep one primary action for each step section."
      ],
      "priority": "first-choice",
      "recommendedFor": [
        "figma-make"
      ],
      "visualDirection": "guidedWorkflow"
    }
  ],
  "selectionPolicy": {
    "mode": "template-first",
    "recommendedFor": [
      "figma-make"
    ],
    "fallback": "Only use freeform composition when no template intent matches.",
    "guards": [
      "Use UDS components only.",
      "Do not use Tailwind utilities or className styling.",
      "Use --uds-* tokens or hardcoded literals only."
    ]
  },
  "visualPolicy": {
    "densePagesRequireVisualAnchors": 3,
    "preferredAnchors": [
      "Toolbar",
      "SectionHeader",
      "Statistics",
      "Status",
      "Tag",
      "Avatar",
      "Checklist",
      "EmptyState",
      "Table"
    ],
    "antiPatterns": [
      "Avoid template output that is only Text, Button, and transparent Containers.",
      "Use surfaced Containers to create separation between summary and detail regions."
    ]
  }
}
