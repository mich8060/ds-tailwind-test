{
    "name": "@chg/unified-design-system",
    "version": "0.1.0",
    "description": "CHG Design System",
    "type": "module",
    "main": "dist/chg-uds.cjs.js",
    "module": "dist/chg-uds.es.js",
    "exports": {
        ".": {
            "import": "./dist/chg-uds.es.js",
            "require": "./dist/chg-uds.cjs.js"
        },
        "./styles.css": "./dist/styles.css",
        "./scss": "./src/scss/index.scss",
        "./scss/*": "./src/scss/*"
    },
    "files": [
        "dist",
        "src/scss"
    ],
    "sideEffects": [
        "**/*.scss",
        "dist/styles.css"
    ],
    "peerDependencies": {
        "@phosphor-icons/react": "^2",
        "react": ">=18.2.0",
        "react-dom": ">=18.2.0"
    },
    "scripts": {
        "build": "vite build",
        "clean": "rimraf dist",
        "prepublishOnly": "npm run build",
        "prepare": "npm run build"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/your/repo.git"
    },
    "publishConfig": {
        "access": "public"
    },
    "devDependencies": {
        "@phosphor-icons/react": "^2.1.10",
        "@vitejs/plugin-react": "^5.0.4",
        "autoprefixer": "^10.4.21",
        "postcss": "^8.5.6",
        "rimraf": "^6.0.1",
        "sass": "^1.93.2",
        "sass-embedded": "^1.93.2",
        "vite": "^7.1.8"
    }
}
